# Select this module in local development. Production should use prex.settings.production.
DJANGO_SETTINGS_MODULE=prex.settings.local
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# PostgreSQL
DB_NAME=prex
DB_USER=postgres
DB_PASSWORD=replace-with-your-database-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Email and frontend URLs
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=
EMAIL_VERIFICATION_URL=http://localhost:5173/verify-email
EMAIL_VERIFICATION_SUCCESS_URL=http://localhost:5173/login

# CoinGecko
COINGECKO_API_KEY= replace-with-your-coingecko-api-key
COINGECKO_API_URL=https://api.coingecko.com/api/v3/coins/markets
COINGECKO_CHART_URL=https://api.coingecko.com/api/v3/coins/
COINGECKO_SEARCH_URL=https://api.coingecko.com/api/v3/search

# Required when DJANGO_SETTINGS_MODULE=prex.settings.production
DJANGO_ALLOWED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
